        new_status, ok = QInputDialog.getItem(self, "Статус", "Выберите:",
                                              ["готово", "ожидает приготовления", "отменен"])
        if ok:
            self.db.execute_query("UPDATE orders SET status=%s WHERE order_id=%s", (new_status, oid))
            self.load_mgr_orders()

