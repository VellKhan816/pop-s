        if status == "Все":
            data = self.db.fetch_all(
                "SELECT o.order_id, u.username, o.status, o.total_amount, o.order_date FROM orders o LEFT JOIN users u ON o.user_id=u.user_id")
        else:
            data = self.db.fetch_all(
                "SELECT o.order_id, u.username, o.status, o.total_amount, o.order_date FROM orders o LEFT JOIN users u ON o.user_id=u.user_id WHERE o.status=%s",
                (status,))

        self.table_mgr_orders.setRowCount(len(data))
        for i, row in enumerate(data):
            for j, val in enumerate(row):
                self.table_mgr_orders.setItem(i, j, QTableWidgetItem(str(val)))

            btn = QPushButton("Изменить статус")
            btn.setStyleSheet("background-color: blue; color: white;")
            btn.clicked.connect(lambda checked, oid=row[0]: self.change_status(oid))
            self.table_mgr_orders.setCellWidget(i, 5, btn)

