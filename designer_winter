class MenuWidget(QWidget):
    def __init__(self, db_manager, auth_manager=None, can_order=True):
        super().__init__()
        self.db = db_manager
        self.auth = auth_manager
        self.can_order = can_order
        self.cart = {}
        self.init_ui()

    def init_ui(self):
        main_layout = QVBoxLayout()
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)

        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarPolicy.ScrollBarAlwaysOff)

        self.list_container = QWidget()
        self.list_layout = QVBoxLayout(self.list_container)
        self.list_layout.setContentsMargins(10, 10, 10, 10)
        self.list_layout.setSpacing(10)
        self.list_layout.setAlignment(Qt.AlignmentFlag.AlignTop)

        self.load_products()

        scroll.setWidget(self.list_container)
        main_layout.addWidget(scroll)

        if self.can_order:
            cart_panel = QWidget()
            cart_panel.setStyleSheet("background-color: lightgray; border-top: 2px solid black; padding: 10px;")
            cart_layout = QHBoxLayout(cart_panel)

            self.cart_label = QLabel("Корзина пуста")
            self.cart_label.setFont(QFont("Arial", 12, QFont.Weight.Bold))
            cart_layout.addWidget(self.cart_label)

            self.btn_cart = QPushButton("Корзина")
            self.btn_cart.setMinimumHeight(40)
            self.btn_cart.setStyleSheet("background-color: green; color: white; font-weight: bold;")
            self.btn_cart.clicked.connect(self.show_cart)
            cart_layout.addWidget(self.btn_cart)

            main_layout.addWidget(cart_panel)

        self.setLayout(main_layout)

    def load_products(self):
        while self.list_layout.count():
            child = self.list_layout.takeAt(0)
            if child.widget():
                child.widget().deleteLater()

        items = self.db.fetch_all("SELECT * FROM menu_items")

        for item in items:
            card = ProductCard(item, self.add_to_cart)
            self.list_layout.addWidget(card)

    def add_to_cart(self, item_id, name, price):
        if item_id in self.cart:
            self.cart[item_id]['qty'] += 1
        else:
            self.cart[item_id] = {'name': name, 'price': float(price), 'qty': 1}
        self.update_cart_label()

    def update_cart_label(self):
        total_items = sum(item['qty'] for item in self.cart.values())
        total_price = sum(item['price'] * item['qty'] for item in self.cart.values())
        self.cart_label.setText(f"В корзине: {total_items} шт. | {total_price:.2f} ₽")

    def show_cart(self):
        if not self.cart:
            QMessageBox.information(self, "Корзина", "Корзина пуста!")
            return

        dialog = QDialog(self)
        dialog.setWindowTitle("Корзина")
        dialog.setMinimumWidth(600)

        d_layout = QVBoxLayout(dialog)
        table = QTableWidget()
        table.setColumnCount(5)
        table.setHorizontalHeaderLabels(["ID", "Блюдо", "Цена", "Кол-во", "Сумма"])
        table.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)

        self.total_label_dialog = QLabel("Итого: 0.00 ₽")
        self.total_label_dialog.setFont(QFont("Arial", 14, QFont.Weight.Bold))
        self.total_label_dialog.setStyleSheet("color: green; padding: 10px; border: 1px solid gray;")
        self.total_label_dialog.setAlignment(Qt.AlignmentFlag.AlignCenter)

        btn_layout = QHBoxLayout()
        btn_order = QPushButton("Оформить заказ")
        btn_order.setStyleSheet("background-color: green; color: white; font-weight: bold;")
        btn_order.clicked.connect(lambda: self.checkout(dialog, self.calculate_total()))

        btn_close = QPushButton("Закрыть")
        btn_close.setStyleSheet("background-color: red; color: white; font-weight: bold;")
        btn_close.clicked.connect(dialog.close)

        btn_layout.addWidget(btn_order)
        btn_layout.addWidget(btn_close)

        d_layout.addWidget(table)
        d_layout.addWidget(self.total_label_dialog)
        d_layout.addLayout(btn_layout)

        self.cart_table_dialog = table
        self.update_cart_table_dialog()
        dialog.exec()

    def calculate_total(self):
        return sum(item['price'] * item['qty'] for item in self.cart.values())

    def update_cart_table_dialog(self):
        self.cart_table_dialog.setRowCount(len(self.cart))
        total = 0
        for i, (item_id, item) in enumerate(self.cart.items()):
            subtotal = item['price'] * item['qty']
            total += subtotal
            self.cart_table_dialog.setItem(i, 0, QTableWidgetItem(str(item_id)))
            self.cart_table_dialog.setItem(i, 1, QTableWidgetItem(item['name']))
            self.cart_table_dialog.setItem(i, 2, QTableWidgetItem(f"{item['price']:.2f} ₽"))

            spin = QSpinBox()
            spin.setValue(item['qty'])
            spin.valueChanged.connect(lambda v, iid=item_id: self.on_qty_change(iid, v))
            self.cart_table_dialog.setCellWidget(i, 3, spin)

            self.cart_table_dialog.setItem(i, 4, QTableWidgetItem(f"{subtotal:.2f} ₽"))

        self.total_label_dialog.setText(f"Итого: {total:.2f} ₽")

    def on_qty_change(self, item_id, qty):
        if qty <= 0:
            del self.cart[item_id]
        else:
            self.cart[item_id]['qty'] = qty
        self.update_cart_table_dialog()
        self.update_cart_label()

    def checkout(self, dialog, total):
        addr, ok = QInputDialog.getText(self, "Адрес", "Введите адрес доставки:")
        if ok:
            try:
                user_id = self.auth.current_user['id'] if self.auth else None
                cursor = self.db.conn.cursor()
                cursor.execute("INSERT INTO orders (user_id, total_amount, delivery_address) VALUES (%s, %s, %s)",
                               (user_id, total, addr))
                order_id = cursor.lastrowid
                for iid, item in self.cart.items():
                    cursor.execute("INSERT INTO order_items (order_id, item_id, quantity) VALUES (%s, %s, %s)",
                                   (order_id, iid, item['qty']))
                self.db.conn.commit()
                cursor.close()
                QMessageBox.information(self, "Успех", f"Заказ #{order_id} оформлен!")
                self.cart.clear()
                self.update_cart_label()
                dialog.close()
            except Exception as e:
                QMessageBox.critical(self, "Ошибка", str(e))


