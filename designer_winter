        btn_out.setStyleSheet("background-color: red; color: white;")
        btn_out.clicked.connect(self.logout)
        layout.addWidget(btn_out)

    def setup_manager_orders(self, widget):
        layout = QVBoxLayout(widget)
        filter_layout = QHBoxLayout()
        filter_layout.addWidget(QLabel("Фильтр:"))
        self.combo_status = QComboBox()
        self.combo_status.addItems(["Все", "готово", "ожидает приготовления"])
        filter_layout.addWidget(self.combo_status)
        layout.addLayout(filter_layout)

        self.table_mgr_orders = QTableWidget()
        self.table_mgr_orders.setColumnCount(6)
        self.table_mgr_orders.setHorizontalHeaderLabels(["ID", "Клиент", "Статус", "Сумма", "Дата", "Действие"])
        self.table_mgr_orders.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)
        self.load_mgr_orders()
        layout.addWidget(self.table_mgr_orders)

        self.combo_status.currentTextChanged.connect(self.load_mgr_orders)

    def load_mgr_orders(self):
