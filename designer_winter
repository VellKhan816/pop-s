        layout = QVBoxLayout(widget)
        self.table_mgr_menu = QTableWidget()
        self.table_mgr_menu.setColumnCount(6)
        self.table_mgr_menu.setHorizontalHeaderLabels(["ID", "Название", "Цена", "Категория", "Описание", "Действия"])
        self.table_mgr_menu.horizontalHeader().setSectionResizeMode(
            QHeaderView.ResizeMode.Interactive)
        self.load_mgr_menu()
        layout.addWidget(self.table_mgr_menu)

        btn_add = QPushButton("Добавить блюдо")
        btn_add.setStyleSheet("background-color: green; color: white;")
        btn_add.clicked.connect(self.add_dish)
        layout.addWidget(btn_add)

    def load_mgr_menu(self):
        items = self.db.fetch_all("SELECT item_id, name, price, category, description FROM menu_items")
        self.table_mgr_menu.setRowCount(len(items))
        for i, item in enumerate(items):
            # item: (id, name, price, category, description)
            self.table_mgr_menu.setItem(i, 0, QTableWidgetItem(str(item[0])))
            self.table_mgr_menu.setItem(i, 1, QTableWidgetItem(item[1]))
            self.table_mgr_menu.setItem(i, 2, QTableWidgetItem(str(item[2])))
            self.table_mgr_menu.setItem(i, 3, QTableWidgetItem(item[3]))
            self.table_mgr_menu.setItem(i, 4, QTableWidgetItem(
                item[4][:30] + "..." if len(item[4]) > 30 else item[4]))

            btn_del = QPushButton("Удалить")
            btn_del.setStyleSheet("background-color: red; color: white;")
            btn_del.clicked.connect(lambda checked, iid=item[0]: self.del_dish(iid))

            btn_edit = QPushButton("Изменить")
            btn_edit.setStyleSheet("background-color: orange; color: white;")
            btn_edit.clicked.connect(lambda checked, iid=item[0]: self.edit_dish(iid))

            btn_widget = QWidget()
            btn_layout = QHBoxLayout(btn_widget)
            btn_layout.setContentsMargins(0, 0, 0, 0)
            btn_layout.addWidget(btn_edit)
            btn_layout.addWidget(btn_del)

            self.table_mgr_menu.setCellWidget(i, 5, btn_widget)

    def add_dish(self):
        dialog = QDialog(self)
        dialog.setWindowTitle("Добавить новое блюдо")
        dialog.setFixedSize(400, 300)

        layout = QFormLayout(dialog)

        inp_name = QLineEdit()
        inp_desc = QTextEdit()
        inp_desc.setMaximumHeight(60)
        inp_price = QDoubleSpinBox()
        inp_price.setMaximum(99999.99)
        inp_category = QComboBox()
        inp_category.addItems(["pizza", "snack", "salad", "dessert", "drink"])
        inp_img = QLineEdit()
        inp_img.setPlaceholderText("images/НазваниеФайла.jpg")

        layout.addRow("Название:", inp_name)
        layout.addRow("Описание:", inp_desc)
        layout.addRow("Цена:", inp_price)
        layout.addRow("Категория:", inp_category)
        layout.addRow("Путь к фото:", inp_img)

        buttons = QDialogButtonBox(QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        buttons.accepted.connect(dialog.accept)
        buttons.rejected.connect(dialog.reject)
        layout.addRow(buttons)

        if dialog.exec() == QDialog.DialogCode.Accepted:
            name = inp_name.text()
            desc = inp_desc.toPlainText()
            price = inp_price.value()
            cat = inp_category.currentText()
            img = inp_img.text()

            if name and price > 0:
                try:
                    self.db.execute_query(
                        "INSERT INTO menu_items (name, description, price, category, image_path, tech_card) VALUES (%s, %s, %s, %s, %s, %s)",
                        (name, desc, price, cat, img, "")
                    )
                    self.load_mgr_menu()  # Перезагружаем таблицу
                    QMessageBox.information(self, "Успех", "Блюдо добавлено!")
                except Exception as e:
                    QMessageBox.critical(self, "Ошибка", f"Не удалось добавить блюдо: {e}")
            else:
                QMessageBox.warning(self, "Ошибка", "Заполните название и цену!")

    def edit_dish(self, item_id):
        item = self.db.fetch_one("SELECT * FROM menu_items WHERE item_id = %s", (item_id,))
        if not item:
            return

        dialog = QDialog(self)
        dialog.setWindowTitle("Редактировать блюдо")
        dialog.setFixedSize(400, 300)

        layout = QFormLayout(dialog)

        inp_name = QLineEdit(item[1])  # name
        inp_desc = QTextEdit(item[2])  # description
        inp_desc.setMaximumHeight(60)
        inp_price = QDoubleSpinBox()
        inp_price.setMaximum(99999.99)
        inp_price.setValue(float(item[3]))  # price
        inp_category = QComboBox()
        inp_category.addItems(["pizza", "snack", "salad", "dessert", "drink"])
        inp_category.setCurrentText(item[4])  # category
        inp_img = QLineEdit(item[5] or "")  # image_path

        layout.addRow("Название:", inp_name)
        layout.addRow("Описание:", inp_desc)
        layout.addRow("Цена:", inp_price)
        layout.addRow("Категория:", inp_category)
        layout.addRow("Путь к фото:", inp_img)

        buttons = QDialogButtonBox(QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        buttons.accepted.connect(dialog.accept)
        buttons.rejected.connect(dialog.reject)
        layout.addRow(buttons)

        if dialog.exec() == QDialog.DialogCode.Accepted:
            name = inp_name.text()
            desc = inp_desc.toPlainText()
            price = inp_price.value()
            cat = inp_category.currentText()
            img = inp_img.text()

            try:
                self.db.execute_query(
                    "UPDATE menu_items SET name=%s, description=%s, price=%s, category=%s, image_path=%s WHERE item_id=%s",
                    (name, desc, price, cat, img, item_id)
                )
                self.load_mgr_menu()
                QMessageBox.information(self, "Успех", "Блюдо обновлено!")
            except Exception as e:
                QMessageBox.critical(self, "Ошибка", f"Не удалось обновить блюдо: {e}")

    def del_dish(self, iid):
        reply = QMessageBox.question(self, "Подтверждение", "Вы уверены, что хотите удалить это блюдо?",
                                     QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        if reply == QMessageBox.StandardButton.Yes:
            self.db.execute_query("DELETE FROM menu_items WHERE item_id=%s", (iid,))
            self.load_mgr_menu()

    def logout(self):
        self.auth.logout()
        self.close()


class AdminWindow(QMainWindow):
    def __init__(self, db, auth):
        super().__init__()
        self.db = db
        self.auth = auth
        self.setWindowTitle(f"Администратор: {auth.current_user['username']}")

        central = QWidget()
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)

        self.tabs = QTabWidget()

        tab_users = QWidget()
        self.setup_admin_users(tab_users)
        self.tabs.addTab(tab_users, "Пользователи")

        tab_analytics = QWidget()
        self.setup_admin_analytics(tab_analytics)
        self.tabs.addTab(tab_analytics, "Аналитика")

        layout.addWidget(self.tabs)

        btn_out = QPushButton("Выйти")
        btn_out.setStyleSheet("background-color: red; color: white;")
        btn_out.clicked.connect(self.logout)
        layout.addWidget(btn_out)

    def setup_admin_users(self, widget):
        layout = QVBoxLayout(widget)
        self.table_users = QTableWidget()
        self.table_users.setColumnCount(3)
        self.table_users.setHorizontalHeaderLabels(["ID", "Логин", "Роль"])
        self.table_users.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)

        users = self.db.fetch_all(
            "SELECT user_id, username, role_name FROM users u JOIN roles r ON u.role_id=r.role_id")
        self.table_users.setRowCount(len(users))
        for i, u in enumerate(users):
            for j, val in enumerate(u):
                self.table_users.setItem(i, j, QTableWidgetItem(str(val)))

        layout.addWidget(self.table_users)

    def setup_admin_analytics(self, widget):
        layout = QVBoxLayout(widget)

        lbl_dev = QLabel("В РАЗРАБОТКЕ")
        lbl_dev.setFont(QFont("Arial", 30, QFont.Weight.Bold))
        lbl_dev.setAlignment(Qt.AlignmentFlag.AlignCenter)
        lbl_dev.setStyleSheet("color: gray;")

        layout.addWidget(lbl_dev)

    def logout(self):
        self.auth.logout()
        self.close()


def main():
    app = QApplication(sys.argv)
    app.setStyle('Fusion')

    db = DatabaseManager()
    auth = AuthManager(db)

    login = LoginWindow(auth)
    if login.exec() == QDialog.DialogCode.Accepted:
        if auth.role == 'client':
            win = ClientWindow(db, auth)
        elif auth.role == 'manager':
            win = ManagerWindow(db, auth)
        elif auth.role == 'admin':
            win = AdminWindow(db, auth)
        else:
            win = QMainWindow()
            w = QWidget()
            l = QVBoxLayout(w)
            l.addWidget(MenuWidget(db, auth, can_order=False))
            win.setCentralWidget(w)

        win.show()
        sys.exit(app.exec())
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
