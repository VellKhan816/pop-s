class AUWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.ui = Ui_auWin()
        self.ui.setupUi(self)
        self.ui.AddButton.clicked.connect(self.add_user)

    def add_user(self):
        log = self.ui.LogEdit.text().strip()
        pas = self.ui.PasEdit.text().strip()
        role = self.ui.RoleEdit.currentText().strip()
        mail = self.ui.MailEdit.text().strip()

        if log and pas and role and mail:
            if add_user_to_db(log,pas,role,mail):
                QMessageBox.information(self,"","")
                self.close()
            else:
                QMessageBox.critical(self,"","")
        else:
            QMessageBox.warning(self,"","")


